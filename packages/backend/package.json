{
  "name": "@throughline/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --conditions=development src/index.ts",
    "start": "tsx --conditions=development src/index.ts",
    "build": "tsc && node scripts/copy-migrations.mjs",
    "typecheck": "tsc -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src test"
  },
  "dependencies": {
    "@throughline/shared": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "chokidar": "^3.6.0",
    "fastify": "^4.27.0",
    "nanoid": "^5.0.7",
    "tsx": "^4.7.2"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/node": "^22",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
